{
  "name": "gonext-template-tooling",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "format": "prettier --write .",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.3",
    "prettier": "^3.6.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yaml,yml}": "prettier --write",
    "*.go": "gofmt -w"
  }
}
