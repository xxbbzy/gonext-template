# Application
APP_NAME=gonext-template
APP_ENV=development
GIN_MODE=release
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

# Database
DB_DRIVER=sqlite
DB_DSN=./data/app.db
# DB_DRIVER=postgres
# DB_DSN=postgres://user:password@localhost:5432/gonext?sslmode=disable

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend
# NEXT_ALLOWED_DEV_ORIGINS=http://192.168.1.122:3000
# NEXT_PUBLIC_API_URL=http://192.168.1.122:8080

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=1m

# File Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads
UPLOAD_ALLOWED_TYPES=.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx
# Optional CDN/custom public URL override for uploaded files
# Example: https://cdn.example.com
UPLOAD_PUBLIC_BASE_URL=

# Storage
STORAGE_DRIVER=local
# S3-compatible object storage settings (required when STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=uploads
S3_USE_SSL=true
S3_FORCE_PATH_STYLE=false

# MinIO example
# STORAGE_DRIVER=s3
# S3_BUCKET=gonext-uploads
# S3_REGION=us-east-1
# S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin
# S3_PREFIX=uploads
# S3_USE_SSL=false
# S3_FORCE_PATH_STYLE=true

# Log
LOG_LEVEL=debug
LOG_FORMAT=json
